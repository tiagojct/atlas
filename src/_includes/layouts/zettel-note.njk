---
layout: layouts/base.njk
bodyClass: reading
---
{%- set maturityLabels = {seedling:"seedling",budding:"budding",evergreen:"evergreen"} %}
<article class="zettel zettel-note">
  <nav class="zettel-breadcrumb"><a href="/">&larr; all notes</a></nav>

  <header class="zettel-note-header">
    <h1>{{ title }}</h1>
    <div class="zettel-note-meta">
      {% if date %}<time datetime="{{ date | isoDate }}">{{ date | zettelDate }}</time>{% endif %}
      <span class="maturity maturity-{{ maturity }}">{{ maturityLabels[maturity] or maturity }}</span>
      {% for tag in tags %}<a href="/tags/{{ tag }}/" class="tag">{{ tag }}</a>{% endfor %}
    </div>
  </header>

  <div class="note-grid">
    <div class="note-main">
      <div class="zettel-note-body">{{ content | safe }}</div>
    </div>
    <aside class="note-side">
      <div id="mini-grafo-container" class="mini-grafo"></div>
    </aside>
  </div>

  {% if linkedNotes.length or backlinks.length or externalLinks.length %}
  <section class="note-connections" aria-label="Ligações desta nota">
    {% if linkedNotes.length %}
    <div class="note-conn">
      <h2><span class="conn-dir" aria-hidden="true">&rarr;</span> Links to</h2>
      <ul class="zettel-link-list">
        {% for n in linkedNotes %}<li><a href="/{{ n.id }}/">{{ n.title }}</a></li>{% endfor %}
      </ul>
    </div>
    {% endif %}
    {% if backlinks.length %}
    <div class="note-conn">
      <h2><span class="conn-dir" aria-hidden="true">&larr;</span> Linked from</h2>
      <ul class="zettel-link-list">
        {% for bl in backlinks %}<li><a href="/{{ bl.id }}/">{{ bl.title }}</a></li>{% endfor %}
      </ul>
    </div>
    {% endif %}
    {% if externalLinks.length %}
    <div class="note-conn">
      <h2>Keep exploring</h2>
      <ul class="explore-list">
        {% for x in externalLinks %}<li><a href="{{ x.url }}" rel="noopener" target="_blank">{{ x.label }}</a></li>{% endfor %}
      </ul>
    </div>
    {% endif %}
  </section>
  {% endif %}

  <script type="application/json" id="mini-grafo-data">
  {
    "center": { "id": "{{ slug }}", "title": {{ title | dump | safe }}, "maturity": "{{ maturity }}", "tags": {{ tags | dump | safe }} },
    "linked": [{% for n in linkedNotes %}{"id": "{{ n.id }}", "title": {{ n.title | dump | safe }}, "maturity": "{{ n.maturity }}"}{% if not loop.last %},{% endif %}{% endfor %}],
    "backlinks": [{% for bl in backlinks %}{"id": "{{ bl.id }}", "title": {{ bl.title | dump | safe }}, "maturity": "{{ bl.maturity }}"}{% if not loop.last %},{% endif %}{% endfor %}]
  }
  </script>
  <script>window.ZETTEL_BASE = "/atlas";</script>
  <script src="https://cdn.jsdelivr.net/npm/d3@7" defer></script>
  <script src="/assets/js/zettel/mini-grafo.js" defer></script>
</article>
