---
layout: layouts/base.njk
permalink: /
lang: pt-PT
title: "Atlas"
description: "Um caderno público: notas atómicas que se ligam entre si, cultivadas ao longo do tempo."
pagefind: false
---
{% import "partials/ledger.njk" as ledger %}
<header class="page-header">
  <h1 class="title">Atlas</h1>
  <p class="lede">Um caderno público: {{ collections.zettelNotes.length }} notas atómicas que se ligam entre si. Segue o <a href="/mapa/">mapa</a>, as <a href="/tags/">tags</a>, ou começa pelas notas centrais. <a href="/sobre/">Sobre este jardim &rarr;</a></p>
</header>

<div class="zettel">

  <section class="grafo-hero" aria-label="Mapa de todas as notas">
    <p class="section-eyebrow">Mapa</p>
    <div class="grafo-canvas">
      <svg id="grafo-svg"></svg>
      <div id="grafo-tooltip" class="grafo-tooltip" aria-hidden="true"></div>
    </div>
    <div class="grafo-foot">
      {% include "partials/grafo-legend.njk" %}
      <a class="grafo-fulllink" href="/mapa/">Mapa em página inteira &rarr;</a>
    </div>
  </section>

  {%- set central = zettelGrafo.nodes | sort(true, false, "score") | head(4) %}
  {%- if central.length and central[0].score > 0 %}
  <section class="home-start" aria-label="Por onde começar">
    <p class="section-eyebrow">Por onde começar</p>
    <ul class="start-grid">
      {%- for n in central %}
      <li><a href="/{{ n.id }}/" class="start-link">{{ n.title }}</a><span class="start-deg">{{ n.score }} ligações</span></li>
      {%- endfor %}
    </ul>
  </section>
  {%- endif %}

  {% if collections.zettelTags.length %}
  {%- set tagsByCount = collections.zettelTags | sort(true, false, "count") %}
  {%- set topTags = tagsByCount | head(18) %}
  {%- set maxCount = tagsByCount[0].count %}
  <section class="zettel-tags" aria-label="Tags">
    <p class="section-eyebrow">Tags</p>
    <div class="zettel-tagcloud">
      {%- for t in topTags %}
      <a href="/tags/{{ t.tag }}/" class="tag" style="font-size:{{ (0.8 + (t.count / maxCount) * 0.45) | round(2) }}rem"><span class="tag-name">{{ t.tag }}</span><span class="tag-count">{{ t.count }}</span></a>
      {%- endfor %}
      {%- if tagsByCount.length > 18 %}<a href="/tags/" class="tag tag-more">+{{ tagsByCount.length - 18 }} mais &rarr;</a>{% endif %}
    </div>
  </section>
  {% endif %}

  {%- set ever = [] %}{% set bud = [] %}{% set seed = [] %}
  {%- for n in collections.zettelNotes %}
    {%- if n.data.maturity == "evergreen" %}{% set _ = ever.push(n) %}
    {%- elif n.data.maturity == "budding" %}{% set _ = bud.push(n) %}
    {%- else %}{% set _ = seed.push(n) %}{% endif %}
  {%- endfor %}
  {%- set everS = ever | sort(true, false, "date") %}
  {%- set budS = bud | sort(true, false, "date") %}
  {%- set seedS = seed | sort(true, false, "date") %}
  <section class="home-all" aria-label="Todas as notas">
    <p class="section-eyebrow">Todas as notas</p>

    {%- if everS.length %}
    <h3 class="feed-head feed-head--evergreen">Consolidadas <span class="feed-count">{{ everS.length }}</span></h3>
    <div class="zettel-feed">{% for n in everS %}{{ ledger.row(n, false, true) }}{% endfor %}</div>
    {%- endif %}

    {%- if budS.length %}
    <h3 class="feed-head feed-head--budding">A crescer <span class="feed-count">{{ budS.length }}</span></h3>
    <div class="zettel-feed">{% for n in budS %}{{ ledger.row(n, false, true) }}{% endfor %}</div>
    {%- endif %}

    {%- if seedS.length %}
    <h3 class="feed-head feed-head--seedling">Esboços <span class="feed-count">{{ seedS.length }}</span></h3>
    <div class="zettel-feed">{% for n in seedS %}{{ ledger.row(n, false, true) }}{% endfor %}</div>
    {%- endif %}
  </section>
</div>

<script type="application/json" id="grafo-data">{{ zettelGrafo | dump | safe }}</script>
<script>window.ZETTEL_BASE = "/atlas";</script>
<script src="https://cdn.jsdelivr.net/npm/d3@7" defer></script>
<script src="/assets/js/zettel/grafo.js" defer></script>
